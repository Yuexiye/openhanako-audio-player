#!/usr/bin/env python
"""
CosyVoice Executor 鈥?澶勭悊 pending TTS 浠诲姟
鐢ㄦ硶: python executor.py --input <taskId> --mode auto

鑷姩鍙戠幇 CosyVoice 椤圭洰鏍圭洰褰曪紙鐜鍙橀噺 COSYVOICE_BASE 鍙€夛級:
  COSYVOICE_BASE         CosyVoice 椤圭洰鏍圭洰褰曪紙涓嶈鍒欒嚜鍔ㄦ悳绱級
  COSYVOICE_MODEL_DIR    妯″瀷鐩綍锛堥粯璁?BASE/models/CosyVoice2-0.5B锛?  HANAKO_AUDIO_PLAYER_DIR  鎻掍欢鏁版嵁鐩綍锛堥粯璁?~/.hanako/plugin-data/hanako-audio-player锛?"""
import sys
import os
import json
import argparse


# 鈹€鈹€ 鑷姩鍙戠幇 CosyVoice 椤圭洰鏍圭洰褰?鈹€鈹€
_COSYVOICE_CACHE = None


def _is_cosyvoice_dir(path):
    return os.path.isdir(os.path.join(path, 'src', 'cosyvoice'))


def find_cosyvoice_base():
    """浠庡涓潵婧愯嚜鍔ㄥ彂鐜?CosyVoice 椤圭洰鏍圭洰褰曪紝鎵惧埌鍚庣紦瀛樺埌閰嶇疆鏂囦欢"""
    global _COSYVOICE_CACHE
    if _COSYVOICE_CACHE:
        return _COSYVOICE_CACHE

    user_home = os.environ.get('USERPROFILE', os.environ.get('HOME', ''))
    cfg_path = os.path.join(
        os.environ.get('HANAKO_AUDIO_PLAYER_DIR', '')
        or os.path.join(user_home, '.hanako', 'plugin-data', 'hanako-audio-player'),
        'cosyvoice_base.txt'
    )

    # 1) 鐜鍙橀噺
    base = os.environ.get('COSYVOICE_BASE', '')
    if base and _is_cosyvoice_dir(base):
        _COSYVOICE_CACHE = base
        return base

    # 2) 缂撳瓨鏂囦欢
    if os.path.exists(cfg_path):
        with open(cfg_path) as f:
            base = f.read().strip()
            if base and _is_cosyvoice_dir(base):
                _COSYVOICE_CACHE = base
                return base

    # 3) 鍚戜笂鎼滅储 cwd 鍙婄埗鐩綍锛堟渶澶?5 灞傦級
    cwd = os.getcwd()
    for _ in range(5):
        for name in ['cosyvoice-tts', 'CosyVoice', 'CosyVoice2']:
            d = os.path.join(cwd, name)
            if _is_cosyvoice_dir(d):
                _save_cosyvoice_base(cfg_path, d)
                _COSYVOICE_CACHE = d
                return d
        parent = os.path.dirname(cwd)
        if parent == cwd:
            break
        cwd = parent

    # 4) 鐢ㄦ埛鐩綍涓嬪父瑙佷綅缃?    if user_home:
        for sub in ['cosyvoice-tts', 'CosyVoice', 'CosyVoice2']:
            for prefix in [user_home, os.path.join(user_home, '.hanako')]:
                d = os.path.join(prefix, sub)
                if _is_cosyvoice_dir(d):
                    _save_cosyvoice_base(cfg_path, d)
                    _COSYVOICE_CACHE = d
                    return d

    # 5) W 鐩?Work 鐩綍涓嬬殑 projects/ 瀛愮洰褰?    work_base = r'W:\Games\Hanako\Work'
    projects_dir = os.path.join(work_base, 'projects')
    for search_dir in [work_base, projects_dir]:
        if not os.path.isdir(search_dir):
            continue
        for name in ['cosyvoice-tts', 'CosyVoice', 'CosyVoice2']:
            d = os.path.join(search_dir, name)
            if _is_cosyvoice_dir(d):
                _save_cosyvoice_base(cfg_path, d)
                _COSYVOICE_CACHE = d
                return d

    return ''


def _save_cosyvoice_base(cfg_path, path):
    try:
        os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
        with open(cfg_path, 'w') as f:
            f.write(path)
    except:
        pass


# 鈹€鈹€ 璺緞瑙ｆ瀽 鈹€鈹€
BASE = find_cosyvoice_base()
if not BASE:
    print('[FATAL] 鏈壘鍒?CosyVoice 椤圭洰鐩綍', file=sys.stderr)
    print('[HINT] 璁剧疆鐜鍙橀噺 COSYVOICE_BASE=CosyVoice椤圭洰鏍圭洰褰曪紝鎴栧皢椤圭洰鏀惧湪甯哥敤璺緞涓?, file=sys.stderr)
    sys.exit(1)

sys.path.insert(0, os.path.join(BASE, 'src'))
sys.path.insert(0, os.path.join(BASE, 'src/third_party/Matcha-TTS'))

from cosyvoice.cli.cosyvoice import AutoModel
import soundfile as sf
import torch

# 鈹€鈹€ 妯″瀷鐩綍 鈹€鈹€
MODEL_DIR = os.environ.get('COSYVOICE_MODEL_DIR', '')
if not MODEL_DIR:
    for candidate in ['CosyVoice2-0.5B', 'CosyVoice3-0.5B', 'CosyVoice-300M']:
        d = os.path.join(BASE, 'models', candidate)
        if os.path.isdir(d):
            MODEL_DIR = d
            break
if not MODEL_DIR:
    print('[FATAL] 鏈壘鍒版ā鍨嬬洰褰曪紝璇疯缃?COSYVOICE_MODEL_DIR', file=sys.stderr)
    sys.exit(1)

# 鈹€鈹€ 娉ㄥ唽璇磋瘽浜哄弬鑰冮厤缃紙鐢ㄤ簬闆舵牱鏈ā寮忎繚鐣欒姘旓級鈹€鈹€
SPEAKER_REFS_PATH = os.path.join(BASE, 'speaker_refs.json')

def load_speaker_refs():
    """鍔犺浇璇磋瘽浜哄弬鑰冮煶棰戦厤缃紝鐢ㄤ簬闆舵牱鏈ā寮忓彇浠?SFT"""
    try:
        if os.path.exists(SPEAKER_REFS_PATH):
            with open(SPEAKER_REFS_PATH, 'r', encoding='utf-8') as f:
                return json.load(f)
    except:
        pass
    return {}

# 鈹€鈹€ 鎻掍欢鏁版嵁鐩綍 鈹€鈹€
USER_HOME = os.environ.get('USERPROFILE', os.environ.get('HOME', ''))

# 鈹€鈹€ 棰勬鏌?whisper 鍙敤鎬?鈹€鈹€
_WHISPER_OK = False
try:
    import whisper
    _WHISPER_OK = True
except ImportError:
    pass

PLUGIN_DATA = os.environ.get(
    'HANAKO_AUDIO_PLAYER_DIR',
    os.path.join(USER_HOME, '.hanako', 'plugin-data', 'hanako-audio-player')
)

TASK_DIR = os.path.join(PLUGIN_DATA, 'tasks')
MEDIA_DIR = os.path.join(PLUGIN_DATA, 'media')
os.makedirs(MEDIA_DIR, exist_ok=True)

_model = None
_speaker_refs = None

def get_model():
    global _model
    if _model is None:
        print(f'鍔犺浇 CosyVoice 妯″瀷 [{MODEL_DIR}] ...', file=sys.stderr)
        _model = AutoModel(model_dir=MODEL_DIR, fp16=True)
        print(f'妯″瀷灏辩华 | CUDA: {torch.cuda.is_available()}', file=sys.stderr)
    return _model

def get_speaker_ref(spk_name):
    """鏌ユ壘璇磋瘽浜哄搴旂殑鍙傝€冮煶棰戦厤缃紙鏀寔涓嫳鏂?ID 鍖归厤锛?""
    global _speaker_refs
    if _speaker_refs is None:
        _speaker_refs = load_speaker_refs()
    # 鐩存帴鍖归厤
    if spk_name in _speaker_refs:
        return _speaker_refs[spk_name]
    # 涓枃鍚嶁啋鑻辨枃鍚嶆槧灏勬煡鎵?    cn_to_en = {
        '娲涚惇甯?: 'luoqixi', '鑹捐帀涓?: 'alice', '鐟炶礉鍗?: 'rebecca',
        '鐖卞讥鏂?: 'aimis', '濂ヨ彶鑾夊▍': 'ophelia', '鎴戠殑澹伴煶': 'my_voice',
    }
    en_name = cn_to_en.get(spk_name, '')
    if en_name and en_name in _speaker_refs:
        return _speaker_refs[en_name]
    return None

def process_task(task_id):
    task_path = os.path.join(TASK_DIR, f'{task_id}.json')
    if not os.path.exists(task_path):
        print(f'[ERROR] 浠诲姟鏂囦欢涓嶅瓨鍦? {task_path}', file=sys.stderr)
        return False

    with open(task_path, 'r', encoding='utf-8') as f:
        task = json.load(f)

    text = task.get('text', '')
    spk = task.get('spk', 'my_voice')
    ref_audio = task.get('refAudio', '')
    ref_text = task.get('refText', '')
    instruct = task.get('instruct', '')

    # 鈹€鈹€ 鑷姩杞綍 鈹€鈹€
    if ref_audio and not ref_text and os.path.exists(ref_audio):
        print(f'[杞綍] 鍙傝€冮煶棰戞棤鏂囨湰锛岃嚜鍔?Whisper 杞綍: {ref_audio}', file=sys.stderr)
        if not _WHISPER_OK:
            print('[杞綍澶辫触] whisper 鏈畨瑁呫€傝杩愯: pip install openai-whisper', file=sys.stderr)
        else:
            try:
                wm = whisper.load_model('base')
                wr = wm.transcribe(ref_audio, language='zh')
                ref_text = wr['text'].strip()
                print(f'[杞綍] 缁撴灉: {ref_text}', file=sys.stderr)
                task['refText'] = ref_text
                with open(task_path, 'w', encoding='utf-8') as f:
                    json.dump(task, f, ensure_ascii=False, indent=2)
            except Exception as e:
                print(f'[杞綍澶辫触] {e}', file=sys.stderr)
    tid = task.get('id', task_id)

    if not text:
        print('[ERROR] 绌烘枃鏈?, file=sys.stderr)
        return False

    output_path = os.path.join(MEDIA_DIR, f'{tid}.wav')
    cosy = get_model()
    spk_list = list(cosy.frontend.spk2info.keys())

    if ref_audio and ref_text and os.path.exists(ref_audio):
        # 鐢ㄦ埛鏄惧紡浼犲叆鍙傝€?鈫?闆舵牱鏈?        print(f'[闆舵牱鏈厠闅哴 鍙傝€? {ref_audio}', file=sys.stderr)
        result = cosy.inference_zero_shot(text, ref_text, ref_audio, stream=False)
    elif spk in spk_list:
        # 宸叉敞鍐岃璇濅汉 鈫?鐢?zero_shot_spk_id 璧?spk2info 瀹屾暣 prompt
        print(f'[宸叉敞鍐岃璇濅汉] spk: {spk}', file=sys.stderr)
        result = cosy.inference_zero_shot(text, '', '', zero_shot_spk_id=spk, stream=False)
    elif spk_list:
        spk = spk_list[0]
        print(f'[fallback] 璇磋瘽浜? {spk}', file=sys.stderr)
        result = cosy.inference_zero_shot(text, '', '', zero_shot_spk_id=spk, stream=False)
    else:
        print('[ERROR] 鏃犲彲鐢ㄨ璇濅汉', file=sys.stderr)
        return False

    for item in result:
        audio = item['tts_speech']
        arr = audio.squeeze().cpu().numpy()
        sf.write(output_path, arr, cosy.sample_rate)
        duration = audio.shape[-1] / cosy.sample_rate
        print(f'杈撳嚭: {output_path}', file=sys.stderr)
        print(f'鏃堕暱: {duration:.1f}s', file=sys.stderr)

        task['status'] = 'completed'
        task['output'] = output_path
        task['duration'] = round(duration, 1)
        with open(task_path, 'w', encoding='utf-8') as f:
            json.dump(task, f, ensure_ascii=False, indent=2)
        return True

    return False

if __name__ == '__main__':
    parser = argparse.ArgumentParser()
    parser.add_argument('--input', required=True, help='浠诲姟 ID')
    parser.add_argument('--mode', default='auto')
    args = parser.parse_args()

    ok = process_task(args.input)
    if ok:
        print(f'[DONE] {args.input}.wav')
        sys.exit(0)
    else:
        print(f'[FAILED] {args.input}', file=sys.stderr)
        sys.exit(1)
